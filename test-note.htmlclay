<!DOCTYPE html>
<html htmlclayid="824f5eba-59e7-4365-9e17-91d9193a7d7f" lang="en"><head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>htmlclay test note</title>
  <style>
    :root { color-scheme: light dark; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font: 16px/1.6 system-ui, -apple-system, "Segoe UI", sans-serif;
      background: #0f1115;
      color: #e6e8ec;
      display: flex;
      justify-content: center;
    }
    main {
      width: min(720px, 100%);
      padding: 48px 24px 96px;
    }
    h1 {
      font-size: 1.6rem;
      margin: 0 0 4px;
    }
    .sub {
      color: #8a93a6;
      font-size: 0.85rem;
      margin: 0 0 28px;
    }
    .card {
      background: #171a21;
      border: 1px solid #262b36;
      border-radius: 12px;
      padding: 20px 22px;
      margin: 0 0 20px;
    }
    [contenteditable] {
      outline: none;
      border-radius: 8px;
      padding: 8px 10px;
      margin: -8px -10px;
      transition: background 0.15s;
    }
    [contenteditable]:focus { background: #1f2530; }
    h2.editable { font-size: 1.15rem; margin: 0 0 12px; }
    ul { padding-left: 22px; margin: 0; }
    ul[contenteditable] { padding: 8px 10px 8px 34px; margin: -8px -10px; }
    li { margin: 4px 0; }
    .meta {
      font-family: ui-monospace, "SF Mono", Menlo, monospace;
      font-size: 0.72rem;
      color: #6b7488;
      word-break: break-all;
      line-height: 1.8;
    }
    .meta b { color: #9aa4ba; font-weight: 600; }
    .bar {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 24px;
      background: rgba(15,17,21,0.9);
      backdrop-filter: blur(8px);
      border-top: 1px solid #262b36;
    }
    button {
      font: inherit;
      font-weight: 600;
      color: #0f1115;
      background: #6ea8fe;
      border: 0;
      border-radius: 8px;
      padding: 10px 20px;
      cursor: pointer;
    }
    button:hover { background: #87b8ff; }
    button:disabled { opacity: 0.5; cursor: default; }
    #status { color: #8a93a6; font-size: 0.85rem; }
    #status.ok { color: #6ee7a8; }
    #status.err { color: #ff8a8a; }
    .hint { margin-left: auto; color: #5a6273; font-size: 0.8rem; }
  </style>
</head>
<body>
  <main>
    <h1>htmlclay test note</h1>
    <p class="sub">Edit anything below, hit Save (or ⌘/Ctrl+S), then reopen the file to confirm it stuck.</p>

    <div class="card">
      <h2 class="editable" contenteditable="">My checklist</h2>
      <ul contenteditable="">
        <li>Open this file in htmlclay</li>
        <li>Change this text</li>
        <li>Save and reopen to verify</li>
      </ul>
    </div>

    <div class="card">
      <p contenteditable="">This whole paragraph is editable too. Type here, save, and the changes are written straight back into the .htmlclay file on disk. No backend, no database, just the file.</p>
    </div>

    <div class="card meta">
      <div><b>Save count:</b> <span id="count">3</span></div>
      <div><b>Last saved:</b> <span id="saved">6/20/2026, 2:37:34 PM</span></div>
      <div><b>htmlclaytoken:</b> <span id="tok">rrQnuZSV5M5KbkpJ2KpGnqI70yZ-j6Y5wIhEvQ4c-W4</span></div>
      <div><b>htmlclayid:</b> <span id="cid">824f5eba-59e7-4365-9e17-91d9193a7d7f</span></div>
    </div>
  </main>

  <div class="bar">
    <button id="save">Save</button>
    <span id="status">Ready.</span>
    <span class="hint">⌘/Ctrl + S to save</span>
  </div>

  <script>
    (function () {
      const html = document.documentElement;
      const statusEl = document.getElementById('status');
      const btn = document.getElementById('save');

      // Surface the server-injected attributes so you can see them live.
      document.getElementById('tok').textContent = html.getAttribute('htmlclaytoken') || '(none — open this via the htmlclay app)';
      document.getElementById('cid').textContent = html.getAttribute('htmlclayid') || '(none yet)';

      function setStatus(msg, kind) {
        statusEl.textContent = msg;
        statusEl.className = kind || '';
      }

      async function save() {
        const token = html.getAttribute('htmlclaytoken');
        if (!token) {
          setStatus('No token — open this file through the htmlclay app, not directly in a browser.', 'err');
          return;
        }

        // Bump the visible save counter before serializing so it persists in the file.
        const countEl = document.getElementById('count');
        countEl.textContent = String((parseInt(countEl.textContent, 10) || 0) + 1);
        document.getElementById('saved').textContent = new Date().toLocaleString();

        const body = '<!DOCTYPE html>\n' + html.outerHTML;

        btn.disabled = true;
        setStatus('Saving…');
        try {
          const res = await fetch('/_/save/' + token, {
            method: 'POST',
            headers: { 'Content-Type': 'text/html' },
            body: body
          });
          if (res.ok) {
            setStatus('Saved to disk.', 'ok');
          } else {
            setStatus('Save failed: ' + res.status + ' ' + (await res.text()), 'err');
          }
        } catch (err) {
          setStatus('Save error: ' + err.message, 'err');
        } finally {
          btn.disabled = false;
        }
      }

      btn.addEventListener('click', save);
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 's') {
          e.preventDefault();
          save();
        }
      });
    })();
  </script>


</body></html>